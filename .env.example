# Proje kökünde .env kopyalayın. Hem Vite hem `server/server.js` burayı okur.

# --- Firebase (Vite) ---
VITE_FIREBASE_API_KEY=YOUR_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-id
VITE_FIREBASE_STORAGE_BUCKET=your-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:0:web:0

# --- MongoDB (server, Mongoose) ---
MONGO_URI=mongodb://127.0.0.1:27017/bilge-ai-asistan

# --- Bilge API (Express; varsayılan kök: http://localhost:5001 — src/lib/apiBase.ts) ---
# VITE_API_BASE=http://localhost:5001
# VITE_BILGE_API_BASE=http://localhost:5001

# --- OpenAI (server, kök .env) — model: gpt-4o-mini (server/openaiService.js) ---
OPENAI_API_KEY=YOUR_KEY
PORT=5000
# CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
